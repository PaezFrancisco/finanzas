# Copia este archivo a .env y completa los valores (nunca subas .env a git)

# IMAP (Gmail: imap.gmail.com:993 SSL; Outlook: outlook.office365.com)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tu_email@gmail.com
IMAP_PASSWORD=pass

# Opcional: carpeta a leer (por defecto INBOX)
IMAP_MAILBOX=INBOX

# Nivel de log: DEBUG, INFO, WARNING, ERROR (o usa: python -m wallet_sync sync -v)
WALLET_LOG_LEVEL=INFO
